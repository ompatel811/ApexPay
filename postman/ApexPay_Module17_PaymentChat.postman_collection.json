{
	"info": {
		"_postman_id": "apexpay-module17-paymentchat-collection",
		"name": "ApexPay Module 17 - Payment Conversations & Financial Messaging",
		"description": "Postman Collection for Module 17 Payment Conversations REST APIs",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Send Money in Chat",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"conversationId\": \"{{conversation_id}}\",\n  \"receiverId\": \"{{receiver_id}}\",\n  \"amount\": 50.00,\n  \"currency\": \"USD\",\n  \"paymentMethod\": \"WALLET\",\n  \"note\": \"Friday Lunch Payment\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/chat/payment/send",
					"host": ["{{base_url}}"],
					"path": ["api", "chat", "payment", "send"]
				}
			}
		},
		{
			"name": "Request Money in Chat",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"conversationId\": \"{{conversation_id}}\",\n  \"receiverId\": \"{{receiver_id}}\",\n  \"amount\": 25.00,\n  \"reason\": \"Office Coffee Split\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/chat/payment/request",
					"host": ["{{base_url}}"],
					"path": ["api", "chat", "payment", "request"]
				}
			}
		},
		{
			"name": "Accept Money Request",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/chat/payment/accept/{{request_id}}",
					"host": ["{{base_url}}"],
					"path": ["api", "chat", "payment", "accept", "{{request_id}}"]
				}
			}
		},
		{
			"name": "Reject Money Request",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/chat/payment/reject/{{request_id}}",
					"host": ["{{base_url}}"],
					"path": ["api", "chat", "payment", "reject", "{{request_id}}"]
				}
			}
		},
		{
			"name": "Share QR Code in Chat",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"conversationId\": \"{{conversation_id}}\",\n  \"receiverId\": \"{{receiver_id}}\",\n  \"qrCodeContent\": \"apexpay://pay?upi=alice@apexpay\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/chat/payment/share-qr",
					"host": ["{{base_url}}"],
					"path": ["api", "chat", "payment", "share-qr"]
				}
			}
		},
		{
			"name": "Get Payment Timeline History",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/chat/payment/history/{{conversation_id}}",
					"host": ["{{base_url}}"],
					"path": ["api", "chat", "payment", "history", "{{conversation_id}}"]
				}
			}
		}
	]
}
